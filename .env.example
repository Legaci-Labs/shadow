# GCP Vertex AI Configuration
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_GEMINI_REGION=us-central1

# Local dev: use `gcloud auth application-default login` or set this:
# GOOGLE_APPLICATION_CREDENTIALS_JSON=<base64-encoded-service-account-json>

# Vercel production (OIDC + Workload Identity Federation):
# GCP_PROJECT_NUMBER=your-project-number
# GCP_WORKLOAD_IDENTITY_POOL_ID=vercel
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=vercel
# GCP_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
